# LangChain API Key for LangSmith Tracing
# Get a free key at https://smith.langchain.com
LANGCHAIN_API_KEY=YOUR_LANGSMITH_API_KEY_HERE
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Jio_RAG_Project

# Jio RAG API Key — used to authenticate requests to this API
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
JIO_RAG_API_KEY=YOUR_API_KEY_HERE

# Comma-separated list of allowed frontend origins
# Example: ALLOWED_ORIGINS=https://yourapp.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Ollama host — override if Ollama is not on localhost (e.g. in Docker)
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# ============================================================
# CLOUD MODEL API KEYS (optional — only needed for cloud LLMs)
# ============================================================

# Anthropic — enables Claude Haiku and Claude Sonnet
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# OpenAI — enables GPT-4o Mini and GPT-4o
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Google — enables Gemini 2.0 Flash and Gemini 1.5 Pro
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ============================================================
# DOCKER SECRETS (production deployment)
# ============================================================
# When running in Docker, sensitive values above should be stored
# as Docker secrets instead of in this file.  See secrets/README.md.
#
# Quick setup:
#   mkdir -p secrets
#   echo "your-api-key" > secrets/JIO_RAG_API_KEY
#   echo "your-langchain-key" > secrets/LANGCHAIN_API_KEY
#
# Ensure secrets/ is listed in .gitignore (it is by default).
#
# The application's secrets_loader.py checks /run/secrets/<NAME>
# first, then falls back to environment variables.  This means:
#   - Local dev: use this .env file (loaded by python-dotenv)
#   - Docker:    use secrets/ files (mounted by docker-compose)
