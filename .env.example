# LangChain API Key for LangSmith Tracing
# Get a free key at https://smith.langchain.com
LANGCHAIN_API_KEY=YOUR_LANGSMITH_API_KEY_HERE
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Jio_RAG_Project

# Jio RAG API Key — used to authenticate requests to this API
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
JIO_RAG_API_KEY=YOUR_API_KEY_HERE

# Comma-separated list of allowed frontend origins
# Example: ALLOWED_ORIGINS=https://yourapp.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Ollama host — override if Ollama is not on localhost (e.g. in Docker)
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434